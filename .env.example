# Copy this file to .env.local and fill in your values.
# Get these from your Supabase project: Settings → API

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Production (Vercel / Netlify / similar): set the same two variables in the
# host's Environment Variables UI (do not commit real keys). After the first
# deploy, share the default URL (*.vercel.app or *.netlify.app) with the client.
# Custom domain: Project → Domains → add domain; paste the DNS records the host
# shows into the client's registrar DNS zone.
